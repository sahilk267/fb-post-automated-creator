# Application Settings
APP_NAME=Content Automation Platform
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./content_platform.db

# API
API_PREFIX=/api/v1

# Meta/Facebook OAuth (single App; do not commit .env with real values)
# FACEBOOK_APP_ID=           # From Meta Developer Console
# FACEBOOK_APP_SECRET=       # From Meta App → Settings
# FACEBOOK_REDIRECT_URI=     # Your callback URL – must match Meta "Valid OAuth Redirect URIs"
#   Local: http://localhost:8000/api/v1/auth/facebook/callback
# TOKEN_ENCRYPTION_KEY=      # Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Or: python -m scripts.generate_encryption_key   (see docs/FACEBOOK_OAUTH_SETUP.md)

# Cron (server-side only; do not expose)
# CRON_SECRET=  # Secret for POST /api/v1/cron/run

# Gemini API (optional – for AI-generated content themes)
# GEMINI_API_KEY=  # Get key at https://aistudio.google.com/apikey

# Celery + Redis (for scheduled Facebook posts; run: redis-server, then celery -A app.scheduler worker -l info)
# CELERY_BROKER_URL=redis://localhost:6379/0
