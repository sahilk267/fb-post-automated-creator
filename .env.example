# Application Settings
APP_NAME=Content Automation Platform
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./content_platform.db

# API
API_PREFIX=/api/v1

# Meta/Facebook OAuth (single App; do not commit .env with real values)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback
# TOKEN_ENCRYPTION_KEY=  # 32-byte URL-safe base64 key for encrypting tokens at rest

# Cron (server-side only; do not expose)
# CRON_SECRET=  # Secret for POST /api/v1/cron/run
